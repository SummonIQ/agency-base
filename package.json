  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --skip-generate",
    "db:studio": "prisma studio --port 10006 --browser none",
    "deps:check": "ncu -i --format group -p bun",
    "dev": "next dev --turbopack --port 10000",
    "build": "bun db:generate && next build",
    "yolo": "git add . && git commit -m 'yolo' && git push",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:a11y": "jest --testPathPattern=.*.a11y.test.tsx?$",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen http://localhost:3030",
    "playwright:install": "playwright install"
  },

  lead                  EnrichedLead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  dataProvider          LeadDataProvider
  sourceApiEndpoint     String?
  dataFields            String[]
  enrichmentDate        DateTime

  termsOfService        String?
  dataProcessingAgreement String?
  complianceNotes       String[]             @default([])


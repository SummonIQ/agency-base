// Alphabetized Models with alphabetized properties

model ApplicationSubmission {
  createdAt              DateTime                       @default(now())
  errorMessage           String?
  id                     String                         @id @default(cuid())
  jobLead                JobLead                        @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  jobLeadId              String
  metadata               Json? // Store submission details, API responses, etc.
  resume                 Resume?                        @relation(fields: [resumeId], references: [id])
  resumeId               String?
  status                 ApplicationStatus              @default(PENDING)
  submissionUrl          String? // URL where application was submitted
  submittedAt            DateTime?
  updatedAt              DateTime                       @updatedAt
  user                   User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String
  userAgent              String? // Track automation vs manual
  wasAutomated           Boolean                        @default(false)
  // Outcome tracking fields
  outcomeEvents          ApplicationOutcomeEvent[]
  lastStatusChangeAt     DateTime?
  responseReceivedAt     DateTime? // When first response was received
  finalOutcomeAt         DateTime? // When final outcome was determined
  interviewCount         Int                            @default(0)
  daysSinceSubmission    Int? // Calculated field for analytics
  daysToResponse         Int? // Days from submission to first response
  daysToFinalOutcome     Int? // Days from submission to final outcome
}

model ApplicationOutcomeEvent {
  id                     String                @id @default(cuid())
  applicationSubmission  ApplicationSubmission @relation(fields: [applicationSubmissionId], references: [id], onDelete: Cascade)
  applicationSubmissionId String
  eventType              String // "status_change", "interview_scheduled", "response_received", etc.
  previousStatus         ApplicationStatus?
  newStatus              ApplicationStatus
  metadata               Json? // Additional event data (interview details, offer amount, etc.)
  notes                  String?
  createdAt              DateTime              @default(now())
  createdBy              String? // Could be "system", "user", or specific user ID
}

model CoverLetter {
  createdAt   DateTime @default(now())
  description String?
  id          String   @id @default(cuid())
  json        Json?
  lead        JobLead? @relation(fields: [leadId], references: [id])
  leadId      String?
  markdown    String?
  name        String
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
}

model JobFitAnalysis {
  additionalMetrics        Json
  createdAt                DateTime             @default(now())
  educationRelevanceScore  Int
  experienceRelevanceScore Int
  summary                  String
  id                       String               @id @default(cuid())
  jobLead                  JobLead?             @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  jobLeadId                String?              @unique
  jobListing               JobListing?          @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  jobListingId             String?
  keywordMatch             Json
  missingKeywords          String[]
  jobLeadOptimization      JobLeadOptimization?
  overallMatchScore        Int
  progress                 Int                  @default(0)
  recommendations          String[]
  resume                   Resume?              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId                 String?
  resumeOptimization       ResumeOptimization?
  resumeRevision           ResumeRevision?      @relation(fields: [resumeRevisionId], references: [id])
  resumeRevisionId         String?              @unique
  skillsAlignment          Json
  status                   JobFitAnalysisStatus @default(QUEUED)
  updatedAt                DateTime             @updatedAt
  user                     User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                   String?
}

model JobLead {
  applicationSubmissions ApplicationSubmission[]
  automationScheduledApplications AutomationScheduledApplication[]
  coverLetters           CoverLetter[]
  createdAt              DateTime                @default(now())
  id                     String                  @id @default(cuid())
  jobFitAnalysis         JobFitAnalysis?
  jobListing             JobListing              @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  jobListingId           String                  @unique
  jobSearch              JobSearch?              @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)
  jobSearchId            String?
  optimization           JobLeadOptimization?
  resumeOptimizations    ResumeOptimization[]
  resumeRevisions        ResumeRevision?
  status                 JobLeadStatus           @default(ADDED)
  title                  String
  updatedAt              DateTime                @updatedAt
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String
}

model JobLeadOptimization {
  createdAt        DateTime                  @default(now())
  id               String                    @id @default(cuid())
  jobFitAnalysis   JobFitAnalysis?           @relation(fields: [jobFitAnalysisId], references: [id])
  jobFitAnalysisId String?                   @unique
  jobLead          JobLead                   @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  jobLeadId        String                    @unique
  progress         Int                       @default(0)
  resumeRevision   ResumeRevision?           @relation(fields: [resumeRevisionId], references: [id])
  resumeRevisionId String?                   @unique
  status           JobLeadOptimizationStatus @default(QUEUED)
  updatedAt        DateTime                  @updatedAt
  user             User?                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String?
}

model JobListing {
  applyOptions             Json?
  benefits                 String[]
  company                  String?
  companyLogoUrl           String?
  createdAt                DateTime         @default(now())
  dentalCoverage           Boolean?
  description              String?
  detectedExtensions       Json?
  extendedDetailsCollected Boolean?         @default(false)
  extensions               String[]
  healthInsurance          Boolean?
  id                       String           @id @default(cuid())
  jobBoard                 JobBoard?
  jobBoardUrl              String?
  jobId                    String           @unique
  jobFitAnalyses           JobFitAnalysis[]
  jobSearch                JobSearch?       @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)
  jobSearchId              String?
  jobType                  JobType?
  lead                     JobLead?
  location                 String?
  paidTimeOff              Boolean?
  postedAt                 DateTime?
  qualifications           String[]         @default([])
  remote                   Boolean?
  requirements             String[]         @default([])
  responsibilities         String[]         @default([])
  salary                   String?
  saved                    Boolean          @default(false)
  scheduleType             String?
  source                   String?
  status                   JobListingStatus @default(UNREVIEWED)
  title                    String
  updatedAt                DateTime         @updatedAt
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                   String
  workFromHome             Boolean?
}

model JobSearch {
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  endedAt     DateTime?
  id          String          @id @default(cuid())
  jobBoard    JobBoard?
  jobBoardUrl String?
  jobLeads    JobLead[]
  jobListings JobListing[]
  location    String?
  metadata    Json?           // Store additional search information, status messages, etc.
  nextToken   String?
  pageDelay   Int?
  progress    Int             @default(0)
  remote      Boolean?
  searchTerm  String
  status      JobSearchStatus @default(QUEUED)
  totalJobs   Int?
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
}

model LinkedInProfile {
  createdAt         DateTime  @default(now())
  email             String?
  firstName         String
  headline          String?
  id                String    @id @default(cuid())
  importedAt        DateTime
  lastName          String
  linkedInId        String
  locationCity      String?
  locationCountry   String?
  profileData       Json?
  profilePictureUrl String?
  publicProfileUrl  String?
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String

  @@unique([userId, linkedInId])
}

model ResumeAnalysis {
  achievements     Json?
  createdAt        DateTime             @default(now())
  formatting       Json?
  grammar          Json?
  id               String               @id @default(cuid())
  keywords         Json?
  optimization     ResumeOptimization?
  progress         Int                  @default(0)
  readability      Json?
  recommendations  Json?
  score            Int?
  sections         Json?
  resume           Resume?              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId         String?              @unique
  resumeRevision   ResumeRevision?      @relation(fields: [resumeRevisionId], references: [id])
  resumeRevisionId String?              @unique
  spelling         Json?
  status           ResumeAnalysisStatus @default(QUEUED)
  strengths        String[]
  summary          String?
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  weaknesses       String[]
}

model ResumeOptimization {
  analysisId                    String?                  @unique
  analysis                      ResumeAnalysis?          @relation(fields: [analysisId], references: [id])
  changelog                     String[]
  estimatedVisibilityBoost      String?
  projectedShortlistProbability Float?
  createdAt                     DateTime                 @default(now())
  id                            String                   @id @default(cuid())
  jobFitAnalysis                JobFitAnalysis?          @relation(fields: [jobFitAnalysisId], references: [id])
  jobFitAnalysisId              String?                  @unique
  jobLead                       JobLead?                 @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  jobLeadId                     String?
  optimizationStrategy          String?
  scoreImprovement              Float?
  score                         Float?
  status                        ResumeOptimizationStatus @default(QUEUED)
  previousScore                 Int?
  progress                      Int                      @default(0)
  resume                        Resume?                  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId                      String?                  @unique
  resumeRevision                ResumeRevision?          @relation(fields: [resumeRevisionId], references: [id])
  resumeRevisionId              String?                  @unique
  scoreDelta                    Float?
  scorePercentChange            Float?
  significantImprovements       String[]
  summary                       String?
  updatedAt                     DateTime                 @updatedAt
  user                          User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                        String?
}

enum ResumeType {
  ORIGINAL
  REVISION
}

model Resume {
  analysis               ResumeAnalysis?
  analysisId             String?                 @unique
  applicationSubmissions ApplicationSubmission[]
  id                     String                  @id @default(cuid())
  createdAt              DateTime                @default(now())
  defaultRevisionId      String?                 @unique
  description            String?
  format                 ResumeFormat?
  jobFitAnalyses         JobFitAnalysis[]
  json                   Json?
  markdown               String?
  name                   String
  optimization           ResumeOptimization?
  performanceMetrics     ResumePerformanceMetric[]
  revisions              ResumeRevision[]
  updatedAt              DateTime                @updatedAt
  url                    String?
  userId                 String
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  createdAt DateTime @default(now())
  expiresAt DateTime
  id        String   @id @default(cuid())
  ipAddress String?
  token     String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  userId    String

  @@unique([token])
  @@map("session")
}

model ResumeRevision {
  id                  String               @id @default(cuid())
  createdAt           DateTime             @default(now())
  description         String?
  format              ResumeFormat?
  jobFitAnalysis      JobFitAnalysis?
  jobLead             JobLead?             @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  jobLeadId           String?              @unique
  jobLeadOptimization JobLeadOptimization?
  json                Json?
  markdown            String?
  name                String
  optimization        ResumeOptimization?
  pdfDocumentUrl      String?
  performanceMetrics  ResumePerformanceMetric[]
  resumeAnalysis      ResumeAnalysis?
  resumeAnalysisId    String?              @unique
  resume              Resume               @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId            String
  updatedAt           DateTime             @updatedAt
  wordDocumentUrl     String?
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
}

model Subscription {
  createdAt            DateTime @default(now())
  currentPeriodEnd     DateTime
  id                   String   @id @default(cuid())
  plan                 String
  status               String
  stripeCustomerId     String   @unique
  stripeSubscriptionId String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String
}

model User {
  accounts               Account[]
  applicationSubmissions ApplicationSubmission[]
  automationSettings     AutomationSettings?
  automationAuditLogs    AutomationAuditLog[]
  automationScheduledApplications AutomationScheduledApplication[]
  coverLetters           CoverLetter[]
  createdAt              DateTime                    @default(now())
  defaultResumeId        String?                     @unique
  defaultRevisionId      String?                     @unique
  email                  String                      @unique
  emailVerified          Boolean                     @default(false)
  firstName              String
  id                     String                      @id @default(cuid())
  image                  String?                     @default("/user.png")
  jobFitAnalyses         JobFitAnalysis[]
  jobLeadOptimizations   JobLeadOptimization[]
  jobListings            JobListing[]
  jobPreferences         UserJobPreferences?
  jobSearches            JobSearch[]
  lastName               String
  leads                  JobLead[]
  linkedInProfiles       LinkedInProfile[]
  resumePerformanceMetrics ResumePerformanceMetric[]
  mobileAudits           MobileResponsivenessAudit[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  name                   String?
  phone                  String?                     @unique
  phoneVerified          DateTime?
  profile                UserProfile?
  resumes                Resume[]
  resumeAnalyses         ResumeAnalysis[]
  resumeOptimizations    ResumeOptimization[]
  resumeRevisions        ResumeRevision[]
  sessions               Session[]
  subscriptions          Subscription[]
  updatedAt              DateTime                    @updatedAt
  verificationTokens     VerificationToken[]
  
  // Agency Management Relations
  clients                Client[]
  agencyLeads            AgencyLead[]
  projects               Project[]
  proposals              Proposal[]
  contracts              Contract[]
  invoices               Invoice[]
  timeEntries            TimeEntry[]
  communications         Communication[]
  outreachTemplates      OutreachTemplate[]
  outreachActivities     OutreachActivity[]
  portfolioProjects      PortfolioProject[]
  services               Service[]
  skills                 Skill[]
  actionTasks            ActionTask[]
  teamMembers            TeamMember[]

  // Lead Intelligence Relations
  enrichedLeads          EnrichedLead[]
  leadIntelligenceSearches      LeadIntelligenceSearch[]
  leadIntelligenceActivities    LeadIntelligenceActivity[]
  leadIntelligenceEmailCampaigns LeadIntelligenceEmailCampaign[]
  leadIntelligenceApiUsage      LeadIntelligenceApiUsageTracking[]
  userIntegrations       UserIntegration[]

  // Email Automation Relations
  emailTemplates         EmailTemplate[]
  emailSequences         EmailSequence[]
  emailSends             EmailSend[]
  emailCampaigns         EmailCampaign[]
  emailSubscribers       EmailSubscriber[]
  subscriberLists        SubscriberList[]

  // LinkedIn Automation Relations
  linkedInProspects      LinkedInProspect[]
  linkedInAutomationSequences LinkedInAutomationSequence[]
  linkedInAutomationActivities LinkedInAutomationActivity[]
  linkedInSearches       LinkedInSearch[]

  // Business Analytics Relations
  deals                  Deal[]
  businessActivities     BusinessActivity[]

  // General Automation Relations
  automationSequences   AutomationSequence[]

  // Recruiting Relations
  candidates            Candidate[]
  jobApplications       JobApplication[]
  talentPools           TalentPool[]
  interviews            Interview[]
  candidateNotes        CandidateNote[]
  applicationNotes      ApplicationNote[]
  jobRequisitions       JobRequisition[]

  // Revenue Relations
  revenueRecords        RevenueRecord[]
  revenueForecasts      RevenueForecast[]

  @@map("user")
}

model UserJobPreferences {
  city            String?
  companySize     CompanySize?
  companyType     String?
  createdAt       DateTime         @default(now())
  experienceLevel ExperienceLevel?
  id              String           @id @default(cuid())
  jobTitles       String[]
  preferRemote    Boolean?
  remoteOnly      Boolean?
  state           String?
  timezone        String?          @default("America/New_York")
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String           @unique
  zipCode         String?
}

model UserProfile {
  city                         String?
  createdAt                    DateTime @default(now())
  educationDegree              String?
  educationEndMonth            Int?
  educationEndYear             Int?
  educationInstitution         String?
  educationInstitutionLocation String?
  educationStartMonth          Int?
  educationStartYear           Int?
  emailAddress                 String?
  firstName                    String?
  githubUrl                    String?
  id                           String   @id @default(cuid())
  lastName                     String?
  linkedinUrl                  String?
  phoneNumber                  String?
  state                        String?
  streetAddress                String?
  updatedAt                    DateTime @updatedAt
  user                         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                       String?  @unique
  websiteUrl                   String?
  zipCode                      String?
}

model VerificationToken {
  expires    DateTime?
  identifier String
  token      String    @unique
  user       User?     @relation(fields: [userId], references: [id])
  userId     String

  @@unique([identifier, token])
}

model Account {
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  accountId             String
  createdAt             DateTime  @default(now())
  id                    String    @id
  idToken               String?
  password              String?
  providerId            String
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  updatedAt             DateTime  @updatedAt
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model MobileResponsivenessAudit {
  id                   String   @id @default(cuid())
  userId               String
  createdAt            DateTime @default(now())
  score                Int
  highSeverityIssues   Int
  mediumSeverityIssues Int
  lowSeverityIssues    Int
  totalIssues          Int
  auditData            Json?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id             String               @id @default(cuid())
  userId         String
  recipientEmail String?
  type           String
  title          String
  content        String
  status         NotificationStatus   @default(PENDING)
  priority       NotificationPriority @default(MEDIUM)
  category       NotificationCategory @default(SYSTEM)
  channels       NotificationChannel[] @default([])
  metadata       Json?
  batchId        String?
  scheduledFor   DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, scheduledFor])
}

model NotificationPreference {
  id                          String                 @id @default(cuid())
  userId                      String                 @unique
  applicationStatusEnabled    Boolean                @default(true)
  interviewRequestsEnabled    Boolean                @default(true)
  networkingRemindersEnabled  Boolean                @default(true)
  shareNotificationsEnabled   Boolean                @default(true)
  resumeFeedbackEnabled       Boolean                @default(true)
  automationEnabled           Boolean                @default(true)
  jobSearchEnabled            Boolean                @default(true)
  resumeAnalysisEnabled       Boolean                @default(true)
  systemNotificationsEnabled  Boolean                @default(true)
  emailEnabled                Boolean                @default(true)
  inAppEnabled                Boolean                @default(true)
  browserEnabled              Boolean                @default(true)
  notificationFrequency       NotificationFrequency  @default(IMMEDIATE)
  quietHoursEnabled           Boolean                @default(false)
  quietHoursStart             String?
  quietHoursEnd               String?
  dailyDigestEnabled          Boolean                @default(false)
  dailyDigestHour             Int?
  weeklyDigestEnabled         Boolean                @default(false)
  weeklyDigestDay             Int?
  weeklyDigestHour            Int?
  batchWindowMinutes          Int                    @default(15)
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  user                        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AutomationSettings {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  // Safety Settings
  requireUserApproval        Boolean  @default(true)
  preventDuplicateApplications Boolean @default(true)
  enableCompanyBlacklist     Boolean  @default(false)
  companyBlacklist           String[] @default([])
  enableKeywordBlacklist     Boolean  @default(false)
  keywordBlacklist           String[] @default([])
  enableSalaryThreshold      Boolean  @default(false)
  minSalaryThreshold         Int      @default(50000)
  maxApplicationsPerCompany  Int      @default(3)
  pauseOnConsecutiveFailures Boolean  @default(true)
  consecutiveFailureThreshold Int     @default(3)
  // Rate Limit Settings
  applicationsPerHour        Int      @default(10)
  applicationsPerDay         Int      @default(50)
  minIntervalMinutes         Int      @default(5)
  respectJobBoardLimits      Boolean  @default(true)
  // Scheduling Settings
  enableSmartScheduling      Boolean  @default(true)
  scheduleWeekdaysOnly       Boolean  @default(true)
  scheduleBusinessHoursOnly  Boolean  @default(true)
  preferredStartHour         Int      @default(9)  // 9 AM
  preferredEndHour           Int      @default(17) // 5 PM
  userTimezone               String   @default("America/New_York")
  prioritizeNewListings      Boolean  @default(true)
  // Automation Control
  isEnabled                  Boolean  @default(false)
  isPaused                   Boolean  @default(false)
  pausedAt                   DateTime?
  pauseReason                String?
  // Tracking
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model AutomationAuditLog {
  id                    String   @id @default(cuid())
  userId                String
  action                String   // "application_submitted", "application_blocked", "settings_changed", "automation_paused", etc.
  actionType            String   // "success", "blocked", "error", "warning"
  metadata              Json?    // Additional context (job details, reason for blocking, etc.)
  jobLeadId             String?
  applicationSubmissionId String?
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
  @@index([action])
}

model AutomationScheduledApplication {
  id                     String    @id @default(cuid())
  userId                 String
  jobLeadId              String
  scheduledFor           DateTime
  priority               Int       @default(0) // Higher number = higher priority
  attemptCount           Int       @default(0)
  maxAttempts            Int       @default(3)
  status                 String    @default("scheduled") // scheduled, processing, completed, failed, cancelled
  lastAttemptAt          DateTime?
  completedAt            DateTime?
  errorMessage           String?
  metadata               Json?     // Platform-specific scheduling data
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobLead                JobLead   @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  
  @@index([userId, status, scheduledFor])
  @@index([scheduledFor])
  @@index([status])
}

model ResumePerformanceMetric {
  id                    String    @id @default(cuid())
  userId                String
  resumeId              String?
  resumeRevisionId      String?
  
  // Performance Tracking
  totalApplications     Int       @default(0)
  totalResponses        Int       @default(0)
  totalInterviews       Int       @default(0) 
  totalOffers           Int       @default(0)
  responseRate          Float     @default(0.0) // responses / applications
  interviewRate         Float     @default(0.0) // interviews / applications
  offerRate             Float     @default(0.0) // offers / applications
  
  // ATS & Performance Scores
  atsScore              Int?      // Latest ATS compatibility score
  atsScoreHistory       Json?     // Array of {score, date} objects for trending
  optimizationScore     Int?      // Latest optimization score from analysis
  optimizationHistory   Json?     // Array of {score, date} objects
  
  // Time-based Analytics
  avgResponseTime       Float?    // Average days to get first response
  avgInterviewTime      Float?    // Average days from application to interview
  avgOfferTime          Float?    // Average days from application to offer
  
  // Keyword & Content Analysis
  keywordEffectiveness  Json?     // Track which keywords correlate with success
  sectionEffectiveness  Json?     // Track which resume sections perform best
  lengthOptimal         Boolean?  // Whether resume length is optimal
  
  // Comparison Metrics
  industryBenchmark     Json?     // How this resume compares to industry standards
  personalBest          Boolean   @default(false) // Mark if this is user's best performing version
  improvementFromPrevious Float? // % improvement from previous version
  
  // Tracking metadata
  calculatedAt          DateTime  @default(now())
  dataRange             Json?     // {startDate, endDate} for the metrics calculation
  sampleSize            Int       @default(0) // Number of applications in the analysis
  
  // Relations
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume                Resume?           @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeRevision        ResumeRevision?   @relation(fields: [resumeRevisionId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([userId, calculatedAt])
  @@index([resumeId])
  @@index([resumeRevisionId])
  @@index([personalBest])
}

// ================================
// AGENCY MANAGEMENT MODELS
// ================================

// Client Management
model Client {
  id                    String                @id @default(cuid())
  name                  String
  email                 String?
  phone                 String?
  website               String?
  industry              String?
  companySize           CompanySize?
  status                ClientStatus          @default(PROSPECT)
  source                LeadSource?
  notes                 String?
  
  // Contact Information
  primaryContactName    String?
  primaryContactEmail   String?
  primaryContactPhone   String?
  primaryContactRole    String?
  
  // Business Details
  annualRevenue         Float?
  employeeCount         Int?
  founded               DateTime?
  description           String?
  
  // Relationship Management
  firstContactDate      DateTime?
  lastContactDate       DateTime?
  nextFollowUpDate      DateTime?
  
  // Financial
  totalRevenue          Float                 @default(0)
  outstandingBalance    Float                 @default(0)
  creditLimit           Float?
  paymentTermsDays      Int                   @default(30)
  
  // Relations
  projects              Project[]
  leads                 AgencyLead[]
  proposals             Proposal[]
  contracts             Contract[]
  invoices              Invoice[]
  communications        Communication[]
  contacts              ClientContact[]
  revenueRecords        RevenueRecord[]
  revenueForecasts      RevenueForecast[]
  jobRequisitions       JobRequisition[]
  candidateFeedback     ClientCandidateFeedback[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([status])
}

model ClientContact {
  id                    String                @id @default(cuid())
  clientId              String
  name                  String
  email                 String?
  phone                 String?
  role                  String?
  isPrimary             Boolean               @default(false)
  notes                 String?
  
  client                Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  communications        Communication[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([clientId])
}

// Lead/Opportunity Management
model AgencyLead {
  id                    String                @id @default(cuid())
  title                 String
  description           String?
  source                LeadSource
  status                LeadStatus            @default(NEW)
  
  // Opportunity Details
  estimatedValue        Float?
  estimatedStartDate    DateTime?
  estimatedDuration     String?               // "3 months", "6 weeks", etc.
  probability           Int?                  // 0-100 percentage
  
  // Contact Information
  contactName           String?
  contactEmail          String?
  contactPhone          String?
  companyName           String?
  
  // Lead Tracking
  firstContactDate      DateTime?
  lastContactDate       DateTime?
  nextFollowUpDate      DateTime?
  lostReason            String?
  wonDate               DateTime?
  
  // Relations
  clientId              String?
  client                Client?               @relation(fields: [clientId], references: [id])
  proposals             Proposal[]
  communications        Communication[]
  activities            OutreachActivity[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([status])
}

// Project Management
model Project {
  id                    String                @id @default(cuid())
  name                  String
  description           String?
  status                ProjectStatus         @default(DRAFT)
  serviceType           ServiceType
  
  // Timeline
  startDate             DateTime?
  endDate               DateTime?
  actualStartDate       DateTime?
  actualEndDate         DateTime?
  
  // Financial
  budgetAmount          Float?
  actualCost            Float                 @default(0)
  profitMargin          Float?
  hourlyRate            Float?
  fixedPrice            Float?
  
  // Progress
  completionPercentage  Int                   @default(0)
  totalHoursEstimated   Float?
  totalHoursActual      Float                 @default(0)
  
  // Relations
  clientId              String
  client                Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contractId            String?
  contract              Contract?             @relation(fields: [contractId], references: [id])
  tasks                 Task[]
  timeEntries           TimeEntry[]
  deliverables          Deliverable[]
  invoices              Invoice[]
  milestones            Milestone[]
  revenueRecords        RevenueRecord[]
  revenueForecasts      RevenueForecast[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([clientId])
  @@index([status])
}

model Task {
  id                    String                @id @default(cuid())
  title                 String
  description           String?
  status                String                @default("TODO") // TODO, IN_PROGRESS, IN_REVIEW, COMPLETED, CANCELLED
  priority              String                @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT

  // Timeline
  dueDate               DateTime?
  completedAt           DateTime?
  estimatedHours        Float?
  actualHours           Float                 @default(0)

  // Sub-task relationships
  parentTaskId          String?
  parentTask            Task?                 @relation("TaskSubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks              Task[]                @relation("TaskSubTasks")

  // Relations
  projectId             String
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId            String?
  assignee              TeamMember?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  timeEntries           TimeEntry[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([projectId, status])
  @@index([parentTaskId])
}

// Team Member Management
model TeamMember {
  id                    String                @id @default(cuid())
  name                  String
  email                 String
  role                  String?               // e.g., "Developer", "Designer", "Project Manager"
  department            String?               // e.g., "Engineering", "Design", "Sales"
  skills                String[]              @default([])
  availability          String                @default("available") // available, busy, unavailable
  image                 String?

  // Relations
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTasks         Task[]                @relation("TaskAssignee")
  actionTasks           ActionTask[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId])
}

// General Action Tasks (not project-specific)
model ActionTask {
  id                    String                @id @default(cuid())
  title                 String
  description           String?
  category              String                // e.g., "Sales", "Marketing", "Operations", "Development"
  status                ActionTaskStatus      @default(TODO)
  priority              ActionTaskPriority    @default(MEDIUM)

  // Timeline
  dueDate               DateTime?
  completedAt           DateTime?
  estimatedHours        Float?
  actualHours           Float                 @default(0)

  // Source tracking
  source                String?               // e.g., "action-plan", "manual", "lead-generation"
  sourceId              String?               // Reference to source entity (e.g., lead ID, project ID)

  // Assignment
  assignedToId          String?
  assignedTo            TeamMember?           @relation(fields: [assignedToId], references: [id])

  // Tags and metadata
  tags                  String[]              @default([])
  metadata              Json?                 // Additional data specific to the task type

  // Progress tracking
  progressPercentage    Int                   @default(0)
  notes                 String?

  // Sub-task relationships
  parentTaskId          String?
  parentTask            ActionTask?           @relation("ActionTaskSubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks              ActionTask[]          @relation("ActionTaskSubTasks")

  // Relations
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId, status])
  @@index([category])
  @@index([dueDate])
  @@index([priority])
  @@index([parentTaskId])
}

model Milestone {
  id                    String                @id @default(cuid())
  name                  String
  description           String?
  dueDate               DateTime
  completedAt           DateTime?
  paymentAmount         Float?                // Payment tied to milestone
  
  projectId             String
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([projectId])
}

model Deliverable {
  id                    String                @id @default(cuid())
  name                  String
  description           String?
  status                String                @default("pending") // pending, in_progress, delivered, accepted
  dueDate               DateTime?
  deliveredAt           DateTime?
  acceptedAt            DateTime?
  
  // File/Link
  fileUrl               String?
  linkUrl               String?
  
  projectId             String
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([projectId])
}

// Proposals & Contracts
model Proposal {
  id                    String                @id @default(cuid())
  title                 String
  status                ProposalStatus        @default(DRAFT)
  
  // Content
  executiveSummary      String?
  scope                 String?
  deliverables          Json?                 // Array of deliverables
  timeline              String?
  terms                 String?
  
  // Financial
  totalAmount           Float
  validUntil            DateTime
  
  // Tracking
  sentAt                DateTime?
  viewedAt              DateTime?
  acceptedAt            DateTime?
  rejectedAt            DateTime?
  rejectionReason       String?
  shareToken            String?               @unique  // For client-facing proposal sharing
  clientFeedback        String?               // Feedback from client during review
  
  // Relations
  clientId              String?
  client                Client?               @relation(fields: [clientId], references: [id])
  leadId                String?
  lead                  AgencyLead?           @relation(fields: [leadId], references: [id])
  contract              Contract?
  proposalItems         ProposalItem[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([status])
}

model ProposalItem {
  id                    String                @id @default(cuid())
  description           String
  quantity              Float                 @default(1)
  rate                  Float
  amount                Float
  
  proposalId            String
  proposal              Proposal              @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  @@index([proposalId])
}

model Contract {
  id                    String                @id @default(cuid())
  title                 String
  status                ContractStatus        @default(DRAFT)
  contractNumber        String                @unique
  
  // Terms
  startDate             DateTime
  endDate               DateTime?
  terms                 String?
  scope                 String?
  
  // Financial
  totalValue            Float
  paymentTerms          String?
  paymentSchedule       Json?                 // Array of payment milestones
  
  // Signatures
  signedByClientAt      DateTime?
  signedByAgencyAt      DateTime?
  clientSignatureName   String?
  agencySignatureName   String?
  
  // Relations
  clientId              String
  client                Client                @relation(fields: [clientId], references: [id])
  proposalId            String?               @unique
  proposal              Proposal?             @relation(fields: [proposalId], references: [id])
  projects              Project[]
  invoices              Invoice[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([clientId])
  @@index([status])
}

// Time Tracking & Billing
model TimeEntry {
  id                    String                @id @default(cuid())
  description           String
  hours                 Float
  date                  DateTime
  billable              Boolean               @default(true)
  status                TimeEntryStatus       @default(DRAFT)
  
  // Rates
  hourlyRate            Float?
  totalAmount           Float?
  
  // Relations
  projectId             String
  project               Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId                String?
  task                  Task?                 @relation(fields: [taskId], references: [id])
  invoiceId             String?
  invoice               Invoice?              @relation(fields: [invoiceId], references: [id])
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([projectId])
  @@index([invoiceId])
}

model Invoice {
  id                    String                @id @default(cuid())
  invoiceNumber         String                @unique
  status                InvoiceStatus         @default(DRAFT)
  
  // Dates
  issueDate             DateTime
  dueDate               DateTime
  paidAt                DateTime?
  
  // Financial
  subtotal              Float
  taxRate               Float                 @default(0)
  taxAmount             Float                 @default(0)
  discount              Float                 @default(0)
  totalAmount           Float
  amountPaid            Float                 @default(0)
  balanceDue            Float
  
  // Details
  notes                 String?
  terms                 String?
  
  // Relations
  clientId              String
  client                Client                @relation(fields: [clientId], references: [id])
  projectId             String?
  project               Project?              @relation(fields: [projectId], references: [id])
  contractId            String?
  contract              Contract?             @relation(fields: [contractId], references: [id])
  timeEntries           TimeEntry[]
  invoiceItems          InvoiceItem[]
  payments              Payment[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([clientId])
  @@index([status])
}

model InvoiceItem {
  id                    String                @id @default(cuid())
  description           String
  quantity              Float                 @default(1)
  rate                  Float
  amount                Float
  
  invoiceId             String
  invoice               Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  @@index([invoiceId])
}

model Payment {
  id                    String                @id @default(cuid())
  amount                Float
  paymentDate           DateTime
  paymentMethod         String?               // credit_card, bank_transfer, check, etc.
  transactionId         String?
  notes                 String?
  
  invoiceId             String
  invoice               Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  
  @@index([invoiceId])
}

// Communication Tracking
model Communication {
  id                    String                @id @default(cuid())
  type                  CommunicationType
  subject               String?
  content               String?
  direction             String                @default("outbound") // inbound, outbound
  
  // Tracking
  sentAt                DateTime?
  receivedAt            DateTime?
  readAt                DateTime?
  respondedAt           DateTime?
  
  // Relations
  clientId              String?
  client                Client?               @relation(fields: [clientId], references: [id])
  clientContactId       String?
  clientContact         ClientContact?        @relation(fields: [clientContactId], references: [id])
  leadId                String?
  lead                  AgencyLead?           @relation(fields: [leadId], references: [id])
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([clientId])
  @@index([leadId])
}

// Outreach & Marketing
model OutreachTemplate {
  id                    String                @id @default(cuid())
  name                  String
  type                  String                // cold_email, follow_up, proposal, linkedin, etc.
  subject               String?
  content               String
  variables             Json?                 // List of variables to replace
  
  // Performance
  timesSent             Int                   @default(0)
  responsesReceived     Int                   @default(0)
  responseRate          Float                 @default(0)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities            OutreachActivity[]
  
  @@index([userId])
}

model OutreachActivity {
  id                    String                @id @default(cuid())
  type                  String                // email, linkedin, call, etc.
  status                String                @default("scheduled") // scheduled, sent, responded, ignored
  scheduledFor          DateTime?
  sentAt                DateTime?
  respondedAt           DateTime?
  
  // Content
  subject               String?
  content               String?
  
  // Relations
  templateId            String?
  template              OutreachTemplate?     @relation(fields: [templateId], references: [id])
  leadId                String?
  lead                  AgencyLead?           @relation(fields: [leadId], references: [id])
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([leadId])
}

// Portfolio & Case Studies
model PortfolioProject {
  id                    String                @id @default(cuid())
  title                 String
  slug                  String                @unique
  description           String?
  
  // Project Details
  clientName            String?
  industry              String?
  serviceType           ServiceType?
  duration              String?
  teamSize              Int?
  budget                String?               // Range like "$50k-$100k"
  
  // Content
  challenge             String?
  solution              String?
  results               String?
  testimonial           String?
  testimonialAuthor     String?
  testimonialRole       String?
  
  // Media
  featuredImage         String?
  images                Json?                 // Array of image URLs
  videoUrl              String?
  liveUrl               String?
  githubUrl             String?
  
  // Technologies
  technologies          String[]
  
  // Visibility
  isPublished           Boolean               @default(false)
  isFeatured            Boolean               @default(false)
  order                 Int                   @default(0)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isPublished])
  @@index([slug])
}

// Skill & Service Management
model Service {
  id                    String                @id @default(cuid())
  name                  String
  slug                  String                @unique
  description           String?
  type                  ServiceType
  
  // Pricing
  hourlyRate            Float?
  minimumEngagement     Float?                // Minimum hours or project size
  
  // Display
  isActive              Boolean               @default(true)
  order                 Int                   @default(0)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isActive])
}

model Skill {
  id                    String                @id @default(cuid())
  name                  String
  category              String                // frontend, backend, database, devops, etc.
  proficiencyLevel      Int                   // 1-5 scale
  yearsOfExperience     Float?
  
  // Validation
  isCertified           Boolean               @default(false)
  certificationName     String?
  certificationDate     DateTime?
  certificationExpiry   DateTime?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@unique([userId, name])
}


  @@index([status])
  @@index([requestType])
}

// User Integration for API credentials
model UserIntegration {
  id                    String               @id @default(cuid())
  userId                String
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider              String               // APOLLO, ZOOMINFO, LINKEDIN, etc.
  accessToken           String
  refreshToken          String?
  expiresAt             DateTime?
  scope                 String?

  createdAt             DateTime             @default(now())

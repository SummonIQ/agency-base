// Lead Intelligence Models

model LeadIntelligenceCompany {
  id                    String               @id @default(cuid())

  // Basic Company Information
  name                  String
  domain                String?              @unique
  website               String?
  linkedinUrl           String?
  description           String?

  // Basic Company Data
  industry              String?
  subIndustry           String?
  companySize           LeadIntelligenceCompanySize?
  employeeCount         Int?
  foundedYear           Int?
  headquarters          String?
  locations             String[]             @default([])

  // Financial Data
  annualRevenue         String?
  fundingStage          String?
  totalFunding          String?

  // Technology Stack
  technologies          String[]             @default([])
  techStack             Json?

  // Enrichment Metadata
  dataProvider          LeadDataProvider     @default(MANUAL)
  apolloId              String?              @unique
  zoomInfoId            String?              @unique
  dataQuality           DataQualityScore     @default(FAIR)

  // Intent Data
  intentSignals         IntentDataSignal[]   @default([])
  intentScore           Float?               @default(0.0)

  // Timestamps
  lastEnrichedAt        DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  // Relations
  leads                 EnrichedLead[]

  @@index([domain])
  @@index([dataProvider])
}

model EnrichedLead {
  id                    String               @id @default(cuid())

  // Personal Information
  firstName             String
  lastName              String
  fullName              String
  email                 String               @unique
  personalEmail         String?
  phone                 String?
  linkedinUrl           String?

  // Professional Information
  jobTitle              String
  department            String?
  seniority             String?
  isDecisionMaker       Boolean              @default(false)

  // Company Association
  companyId             String
  company               LeadIntelligenceCompany          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Lead Management
  status                LeadIntelligenceStatus           @default(NEW)
  leadScore             Float?               @default(0.0)
  qualificationNotes    String?
  assignedToUserId      String?
  assignedTo            User?                @relation(fields: [assignedToUserId], references: [id])

  // Enrichment Data
  dataProvider          LeadDataProvider     @default(MANUAL)
  apolloPersonId        String?              @unique
  zoomInfoPersonId      String?              @unique
  dataQuality           DataQualityScore     @default(FAIR)

  // Timestamps
  lastEnrichedAt        DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  // Relations
  activities            LeadIntelligenceActivity[]
  searchResults         LeadIntelligenceSearchResult[]
  dataConsents          LeadIntelligenceDataConsent[]
  dataAttributions      LeadIntelligenceDataAttribution[]

  @@index([email])
  @@index([assignedToUserId])
  @@index([status])
  @@index([dataProvider])
}

model LeadIntelligenceSearch {
  id                    String               @id @default(cuid())
  userId                String
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  searchQuery           String
  filters               Json?                // Search filters used
  status                String               @default("PROCESSING") // PROCESSING, COMPLETED, FAILED
  totalResults          Int                  @default(0)

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  completedAt           DateTime?

  // Relations
  results               LeadIntelligenceSearchResult[]

  @@index([userId])
  @@index([status])
}

model LeadIntelligenceSearchResult {
  id                    String               @id @default(cuid())

  // Search Association
  leadSearchId          String
  leadSearch            LeadIntelligenceSearch           @relation(fields: [leadSearchId], references: [id], onDelete: Cascade)

  // Basic Lead Data (before enrichment)
  firstName             String?
  lastName              String?
  email                 String?
  jobTitle              String?
  companyName           String?
  companyDomain         String?

  // Metadata
  dataProvider          LeadDataProvider
  externalId            String               // ID from Apollo/ZoomInfo
  processingStatus      String               @default("QUEUED") // QUEUED, PROCESSING, COMPLETED, FAILED

  // Enrichment Link
  enrichedLeadId        String?
  enrichedLead          EnrichedLead?        @relation(fields: [enrichedLeadId], references: [id])
  enrichmentQueue       LeadIntelligenceEnrichmentQueue[]

  createdAt             DateTime             @default(now())
  processedAt           DateTime?

  @@index([leadSearchId])
  @@index([processingStatus])
}

model LeadIntelligenceEnrichmentQueue {
  id                    String               @id @default(cuid())

  searchResultId        String
  searchResult          LeadIntelligenceSearchResult     @relation(fields: [searchResultId], references: [id], onDelete: Cascade)

  // Queue Management
  priority              String               @default("NORMAL") // HIGH, NORMAL, LOW
  status                String               @default("QUEUED") // QUEUED, PROCESSING, COMPLETED, FAILED, RETRYING
  attempts              Int                  @default(0)

  // Processing Details
  dataProvider          LeadDataProvider?
  dataQuality           DataQualityScore?
  error                 String?

  // Timestamps
  scheduledAt           DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([status, priority])
  @@index([scheduledAt])
}

model LeadIntelligenceActivity {
  id                    String               @id @default(cuid())

  // Lead Association
  leadId                String
  lead                  EnrichedLead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Activity Details
  type                  String               // CALL, EMAIL, MEETING, NOTE, LINKEDIN_MESSAGE, DEMO, PROPOSAL_SENT, FOLLOW_UP, SCORING
  description           String
  metadata              Json?

  // User Association
  userId                String?
  user                  User?                @relation(fields: [userId], references: [id])

  createdAt             DateTime             @default(now())

  @@index([leadId])
  @@index([type])
  @@index([userId])
}

model LeadIntelligenceEmailCampaign {
  id                    String               @id @default(cuid())

  name                  String
  subject               String
  content               String

  // Campaign Settings
  status                String               @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT, PAUSED
  scheduledAt           DateTime?

  // Template Data
  isTemplate            Boolean              @default(false)
  templateVariables     Json?

  // Targeting
  targetCriteria        Json?                // Lead filtering criteria
  estimatedReach        Int?

  // Performance
  sentCount             Int                  @default(0)
  openCount             Int                  @default(0)
  clickCount            Int                  @default(0)
  replyCount            Int                  @default(0)

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  userId                String
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model LeadIntelligenceApiUsageTracking {
  id                    String               @id @default(cuid())

  userId                String
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider              LeadDataProvider
  endpoint              String
  date                  DateTime             // Day-level tracking

  // Usage Metrics
  requestCount          Int                  @default(0)
  successCount          Int                  @default(0)
  errorCount            Int                  @default(0)
  rateLimitedCount      Int                  @default(0)

  // Timestamps
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([userId, provider, endpoint, date])
  @@index([userId, provider, date])
  @@index([date])
}

// GDPR Compliance Models

model LeadIntelligenceDataConsent {

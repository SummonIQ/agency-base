// Email Automation Models

model EmailTemplate {
  id                    String                @id @default(cuid())
  name                  String
  subject               String
  content               String                // HTML content
  textContent           String?               // Plain text version
  type                  EmailTemplateType
  variables             String[]              // List of variables used in template
  isActive              Boolean               @default(true)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Analytics
  sentCount             Int                   @default(0)
  openCount             Int                   @default(0)
  clickCount            Int                   @default(0)
  replyCount            Int                   @default(0)

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  // Relations
  sequenceSteps         EmailSequenceStep[]
  emailSends            EmailSend[]

  @@index([userId])
  @@index([type])
}

model EmailSequence {
  id                    String                @id @default(cuid())
  name                  String
  description           String?
  status                EmailSequenceStatus   @default(DRAFT)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Settings
  isActive              Boolean               @default(false)
  maxEmails             Int?                  // Maximum emails to send per day

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  // Relations
  steps                 EmailSequenceStep[]
  recipients            EmailSequenceRecipient[]

  @@index([userId])
  @@index([status])
}

model EmailSequenceStep {
  id                    String                @id @default(cuid())
  sequenceId            String
  sequence              EmailSequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  templateId            String
  template              EmailTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)

  stepNumber            Int                   // Order in sequence (1, 2, 3...)
  delayDays             Int                   @default(0) // Days to wait before sending
  delayHours            Int                   @default(0) // Additional hours to wait

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([sequenceId, stepNumber])
  @@index([sequenceId])
}

model EmailSequenceRecipient {
  id                    String                @id @default(cuid())
  sequenceId            String
  sequence              EmailSequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  email                 String
  name                  String?
  customFields          Json?                 // Additional data for personalization
  status                RecipientStatus       @default(ACTIVE)

  // Sequence progress
  currentStep           Int                   @default(0) // 0 = not started
  nextSendAt            DateTime?
  completedAt           DateTime?
  unsubscribedAt        DateTime?

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  // Relations
  emailSends            EmailSend[]

  @@unique([sequenceId, email])
  @@index([sequenceId])
  @@index([email])
  @@index([nextSendAt])
}

model EmailSend {
  id                    String                @id @default(cuid())
  templateId            String?
  template              EmailTemplate?        @relation(fields: [templateId], references: [id])
  recipientId           String?
  recipient             EmailSequenceRecipient? @relation(fields: [recipientId], references: [id])

  // Email details
  toEmail               String
  toName                String?
  fromEmail             String
  fromName              String?
  subject               String
  htmlContent           String
  textContent           String?

  // Status tracking
  status                EmailSendStatus       @default(PENDING)
  externalId            String?               // SendGrid message ID

  // Analytics timestamps
  sentAt                DateTime?
  deliveredAt           DateTime?
  openedAt              DateTime?
  firstOpenedAt         DateTime?
  clickedAt             DateTime?
  firstClickedAt        DateTime?
  bouncedAt             DateTime?
  unsubscribedAt        DateTime?
  repliedAt             DateTime?

  // Metadata
  metadata              Json?
  errorMessage          String?

  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId])
  @@index([status])
  @@index([toEmail])
  @@index([sentAt])
}

// ================================
// LINKEDIN AUTOMATION MODELS
// ================================

// General Automation Enums
enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum AutomationTrigger {
  MANUAL
  LEAD_CREATED
  PROSPECT_CONNECTED
  EMAIL_OPENED
  FORM_SUBMITTED
}

enum AutomationStepType {
  EMAIL
  LINKEDIN_CONNECTION
  LINKEDIN_MESSAGE
  WAIT
  CONDITION
}

// LinkedIn Automation Enums
enum LinkedInConnectionStatus {
  PENDING
  CONNECTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

enum LinkedInProspectStatus {
  NEW
  CONTACTED
  CONNECTED
  QUALIFIED
  CONVERTED
  DISQUALIFIED
}

enum LinkedInAutomationStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum LinkedInMessageType {
  CONNECTION_REQUEST
  FOLLOW_UP
  NURTURE
  PITCH
  THANK_YOU
}

// LinkedIn Prospect Management
model LinkedInProspect {
  id                    String                @id @default(cuid())
  
  // LinkedIn Profile Data
  linkedInId            String                @unique
  firstName             String
  lastName              String
  headline              String?
  location              String?
  industry              String?
  company               String?
  profileUrl            String
  connectionDegree      String                // 1st, 2nd, 3rd
  premium               Boolean               @default(false)
  
  // Prospect Management
  status                LinkedInProspectStatus @default(NEW)
  score                 Int                   @default(50) // 0-100 lead score
  notes                 String?
  tags                  String[]              @default([])
  source                String                @default("search") // search, import, referral
  
  // Contact Information
  email                 String?
  phone                 String?
  
  // Tracking
  lastContact           DateTime?
  nextFollowUp          DateTime?
  
  // User Association
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relations
  connections           LinkedInConnection[]
  messages              LinkedInMessage[]
  automationActivities LinkedInAutomationActivity[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([linkedInId])
}

// LinkedIn Connection Tracking
model LinkedInConnection {
  id                    String                @id @default(cuid())
  
  prospectId            String
  prospect              LinkedInProspect      @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  
  status                LinkedInConnectionStatus @default(PENDING)
  message               String?               // Connection request message
  
  sentAt                DateTime              @default(now())
  respondedAt           DateTime?
  expiresAt             DateTime?
  
  // Metadata
  metadata              Json?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([prospectId])
  @@index([status])
  @@index([sentAt])
}

// LinkedIn Message Tracking
model LinkedInMessage {
  id                    String                @id @default(cuid())
  
  prospectId            String
  prospect              LinkedInProspect      @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  
  type                  LinkedInMessageType
  content               String
  status                String                @default("sent") // sent, read, replied
  
  sentAt                DateTime              @default(now())
  readAt                DateTime?
  repliedAt             DateTime?
  
  // Thread tracking
  threadId              String?
  isReply               Boolean               @default(false)
  
  // Metadata
  metadata              Json?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([prospectId])
  @@index([type])
  @@index([sentAt])
}

// LinkedIn Automation Sequences
model LinkedInAutomationSequence {
  id                    String                @id @default(cuid())
  
  name                  String
  description           String?
  status                LinkedInAutomationStatus @default(ACTIVE)
  
  // Limits and Settings
  dailyLimit            Int                   @default(50)
  weeklyLimit           Int                   @default(200)
  isActive              Boolean               @default(true)
  
  // User Association
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relations
  steps                 LinkedInAutomationStep[]
  activities            LinkedInAutomationActivity[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([status])
}

// LinkedIn Automation Steps
model LinkedInAutomationStep {
  id                    String                @id @default(cuid())
  
  sequenceId            String
  sequence              LinkedInAutomationSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  
  stepNumber            Int                   // Order in sequence
  type                  LinkedInMessageType   // connection_request, message, follow_up
  delayDays             Int                   @default(0)
  content               String?               // Message template
  isActive              Boolean               @default(true)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@unique([sequenceId, stepNumber])
  @@index([sequenceId])
}

// LinkedIn Automation Activity Log
model LinkedInAutomationActivity {
  id                    String                @id @default(cuid())
  
  prospectId            String?
  prospect              LinkedInProspect?     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  
  sequenceId            String?
  sequence              LinkedInAutomationSequence? @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  
  type                  String                // connection_request, message, profile_view, etc.
  status                String                // success, failed, skipped
  description           String
  
  // Metadata
  metadata              Json?
  errorMessage          String?
  
  // User Association
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([prospectId])
}

// LinkedIn Search History
model LinkedInSearch {
  id                    String                @id @default(cuid())
  
  searchQuery           String
  filters               Json?                 // Search filters used
  totalResults          Int                   @default(0)
  
  // User Association
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  
  @@index([userId])
}

// Revenue Analytics Data Storage
model Deal {
  id                    String                @id @default(cuid())
  
  clientName            String
  value                 Float
  stage                 String                // discovery, proposal, negotiation, closed-won, closed-lost
  probability           Int                   // 0-100
  expectedCloseDate     DateTime
  source                String                // Network Referral, LinkedIn, Apollo.io, Cold Outreach
  
  // Tracking
  lastActivity          DateTime?
  notes                 String?
  
  // User Association
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([stage])
  @@index([source])
}

// Business Activity Tracking
model BusinessActivity {
  id                    String                @id @default(cuid())
  
  type                  String                // email_sent, linkedin_connection, call_scheduled, proposal_sent
  description           String
  
  // Associated Records
  leadId                String?               // Reference to EnrichedLead
  prospectId            String?               // Reference to LinkedInProspect
  dealId                String?               // Reference to Deal
  
  // Metadata
  metadata              Json?
  
  // User Association
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([leadId])
  @@index([prospectId])
}

// ================================
// GENERAL AUTOMATION MODELS
// ================================

// General Automation Sequences (for multi-channel campaigns)
model AutomationSequence {
  id                    String                @id @default(cuid())
  
  name                  String
  description           String?
  type                  String                // EMAIL, LINKEDIN, MIXED
  trigger               AutomationTrigger
  status                AutomationStatus      @default(DRAFT)
  
  // Targeting
  targetAudience        Json?                 // Industries, job titles, company sizes, etc.
  
  // Timing
  activatedAt           DateTime?
  pausedAt              DateTime?
  
  // Relations
  steps                 AutomationStep[]
  recipients            AutomationRecipient[]
  
  // User Association
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([type])
}

// Automation Steps
model AutomationStep {
  id                    String                @id @default(cuid())
  
  sequenceId            String
  sequence              AutomationSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  
  stepNumber            Int
  type                  AutomationStepType
  name                  String
  
  // Timing
  delayDays             Int                   @default(0)
  delayHours            Int                   @default(0)
  
  // Content
  templateId            String?               // Reference to EmailTemplate
  customContent         String?
  
  // Conditions
  conditions            Json?                 // Array of condition objects
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([sequenceId])
  @@index([stepNumber])
}

// Automation Recipients
model AutomationRecipient {
  id                    String                @id @default(cuid())
  
  sequenceId            String
  sequence              AutomationSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  
  // Recipient Info
  leadId                String?               // Reference to EnrichedLead
  prospectId            String?               // Reference to LinkedInProspect
  email                 String
  firstName             String?
  lastName              String?
  company               String?
  jobTitle              String?
  
  // Custom Fields
  customFields          Json?
  
  // Progress Tracking
  currentStep           Int                   @default(1)
  status                String                @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, UNSUBSCRIBED, BOUNCED
  
  // Timing
  startedAt             DateTime              @default(now())
  completedAt           DateTime?
  lastActivityAt        DateTime              @default(now())
  
  // Metadata
  metadata              Json?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([sequenceId])
  @@index([email])
  @@index([status])
  @@index([currentStep])
}

// Email Marketing Models
model EmailCampaign {
  id                    String                @id @default(cuid())
  name                  String
  type                  String                // newsletter, promotional, transactional, automation
  subject               String
  content               String                @db.Text
  status                String                @default("draft") // draft, scheduled, active, paused, completed

  // Scheduling
  scheduledDate         DateTime?
  sentAt                DateTime?

  // Metadata
  metadata              Json?

  // Relations
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients            CampaignRecipient[]
  opens                 CampaignOpen[]
  clicks                CampaignClick[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}


model EmailSubscriber {
  id                    String                @id @default(cuid())
  email                 String
  firstName             String?
  lastName              String?
  status                String                @default("active") // active, unsubscribed, bounced

  // Subscription details
  subscribedAt          DateTime              @default(now())
  unsubscribedAt        DateTime?
  lastActivity          DateTime?

  // Custom fields
  customFields          Json?

  // Relations
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lists                 SubscriberList[]
  campaignRecipients    CampaignRecipient[]
  opens                 CampaignOpen[]
  clicks                CampaignClick[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([email, userId])
  @@index([userId])
  @@index([status])
}

model SubscriberList {
  id                    String                @id @default(cuid())
  name                  String
  description           String?

  // Relations
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscribers           EmailSubscriber[]
  campaignRecipients    CampaignRecipient[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId])
}

model CampaignRecipient {
  id                    String                @id @default(cuid())

  // Relations
  campaignId            String
  campaign              EmailCampaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriberId          String?
  subscriber            EmailSubscriber?      @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  recipientListId       String?
  recipientList         SubscriberList?       @relation(fields: [recipientListId], references: [id], onDelete: Cascade)

  // Individual recipient data (for non-subscriber recipients)
  email                 String?
  firstName             String?
  lastName              String?

  // Delivery status
  status                String                @default("pending") // pending, sent, failed, bounced
  sentAt                DateTime?

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([campaignId])
  @@index([subscriberId])
  @@index([status])
}

model CampaignOpen {
  id                    String                @id @default(cuid())

  // Relations
  campaignId            String
  campaign              EmailCampaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriberId          String?
  subscriber            EmailSubscriber?      @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  // Tracking data
  email                 String
  ipAddress             String?
  userAgent             String?
  openedAt              DateTime              @default(now())

  @@index([campaignId])
  @@index([subscriberId])
  @@index([email])
}

model CampaignClick {
  id                    String                @id @default(cuid())

  // Relations
  campaignId            String
  campaign              EmailCampaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriberId          String?
  subscriber            EmailSubscriber?      @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  // Tracking data
  email                 String
  url                   String
  ipAddress             String?
  userAgent             String?
  clickedAt             DateTime              @default(now())

  @@index([campaignId])
  @@index([subscriberId])
  @@index([email])
}


// Recruiting Models
model Candidate {
  id                    String                @id @default(cuid())
  name                  String
  email                 String
  phone                 String?
  location              String?
  currentRole           String?
  experience            String?
  education             String?
  skills                String[]
  status                String                @default("new") // new, active, interviewing, offered, hired, rejected
  rating                Int?                  // 1-5 star rating
  resumeUrl             String?
  linkedInUrl           String?
  portfolioUrl          String?

  // Custom fields
  customFields          Json?

  // Relations
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications          JobApplication[]
  interviews            Interview[]
  notes                 CandidateNote[]
  talentPools           TalentPoolCandidate[]
  clientFeedback        ClientCandidateFeedback[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId])
  @@index([status])
  @@index([email])
}

model JobApplication {
  id                    String                @id @default(cuid())
  position              String
  company               String
  department            String?
  status                String                @default("new") // new, screening, interview, offer, hired, rejected, withdrawn
  stage                 String?               // Current pipeline stage
  salary                String?
  location              String?
  type                  String?               // full-time, part-time, contract
  score                 Int?                  // Fit score 0-100

  // Important dates
  appliedDate           DateTime              @default(now())
  lastActivity          DateTime              @default(now())

  // Relations
  candidateId           String
  candidate             Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  requisitionId         String?
  requisition           JobRequisition?       @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews            Interview[]
  notes                 ApplicationNote[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId])
  @@index([candidateId])
  @@index([requisitionId])
  @@index([status])
}

model TalentPool {
  id                    String                @id @default(cuid())
  name                  String
  description           String?
  category              String                // Engineering, Product, Design, Data, etc.
  tags                  String[]
  qualityScore          Float?                // Average quality score

  // Relations
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates            TalentPoolCandidate[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId])
  @@index([category])
}

model TalentPoolCandidate {
  id                    String                @id @default(cuid())

  // Relations
  talentPoolId          String
  talentPool            TalentPool            @relation(fields: [talentPoolId], references: [id], onDelete: Cascade)
  candidateId           String
  candidate             Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Pool-specific data
  addedAt               DateTime              @default(now())
  isActive              Boolean               @default(true)
  notes                 String?

  @@unique([talentPoolId, candidateId])
  @@index([talentPoolId])
  @@index([candidateId])
}

model Interview {
  id                    String                @id @default(cuid())
  type                  String                // phone, video, onsite, technical
  status                String                @default("scheduled") // scheduled, completed, cancelled, rescheduled
  scheduledAt           DateTime
  duration              Int?                  // minutes
  interviewer           String?
  notes                 String?
  score                 Int?                  // 1-5 rating
  feedback              String?

  // Relations
  candidateId           String
  candidate             Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applicationId         String?
  application           JobApplication?       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([candidateId])
  @@index([applicationId])
  @@index([userId])
  @@index([scheduledAt])
}

model CandidateNote {
  id                    String                @id @default(cuid())
  content               String
  type                  String?               // general, interview, phone_call, email

  // Relations
  candidateId           String
  candidate             Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([candidateId])
  @@index([userId])
}

model ApplicationNote {
  id                    String                @id @default(cuid())
  content               String
  type                  String?               // general, interview, follow_up

  // Relations
  applicationId         String
  application           JobApplication        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([applicationId])
  @@index([userId])
}

// Job Requisition Model (Client Job Openings)
model JobRequisition {
  id                    String                @id @default(cuid())
  title                 String
  description           String
  department            String?
  location              String?
  type                  String                @default("full-time") // full-time, part-time, contract
  status                String                @default("open") // open, on-hold, filled, cancelled
  priority              String                @default("medium") // low, medium, high, urgent
  
  // Requirements
  requiredSkills        String[]
  preferredSkills       String[]
  experienceLevel       String?               // entry, mid, senior, lead, principal
  minExperience         Int?                  // years
  maxExperience         Int?                  // years
  education             String?
  certifications        String[]
  
  // Compensation
  salaryMin             Float?
  salaryMax             Float?
  currency              String                @default("USD")
  benefits              String[]
  
  // Timeline
  startDate             DateTime?
  targetFillDate        DateTime?
  filledDate            DateTime?
  
  // Hiring Details
  hiringManager         String?
  numberOfPositions     Int                   @default(1)
  positionsFilled       Int                   @default(0)
  
  // Client Portal Settings
  isVisibleToClient     Boolean               @default(true)
  shareToken            String?               @unique  // For client-facing portal access
  
  // Relations
  clientId              String
  client                Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications          JobApplication[]
  clientFeedback        ClientCandidateFeedback[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([clientId])
  @@index([userId])
  @@index([status])
}

// Client Feedback on Candidates
model ClientCandidateFeedback {
  id                    String                @id @default(cuid())
  
  // Feedback Details
  rating                Int?                  // 1-5 star rating
  status                String                @default("pending") // pending, interested, not-interested, interview-requested, rejected
  comments              String?
  strengths             String[]
  concerns              String[]
  
  // Decision
  moveForward           Boolean?              // true = move forward, false = reject, null = pending
  interviewRequested    Boolean               @default(false)
  preferredInterviewDates String[]            // Array of date strings
  
  // Relations
  requisitionId         String
  requisition           JobRequisition        @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  candidateId           String
  candidate             Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@unique([requisitionId, candidateId, clientId])
  @@index([requisitionId])
  @@index([candidateId])
  @@index([clientId])
  @@index([status])
}

// Revenue Tracking Models
model RevenueRecord {
  id                    String                @id @default(cuid())
  amount                Float
  currency              String                @default("USD")
  type                  RevenueType
  status                RevenueStatus         @default(PENDING)
  description           String?
  category              String?               // consulting, retainer, project, subscription
  source                String?               // client name or source
  recurringPeriod       RecurringPeriod?      // for subscription revenue
  
  // Date tracking
  recordedDate          DateTime              @default(now())
  periodStart           DateTime
  periodEnd             DateTime
  
  // Relations
  clientId              String?
  client                Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId             String?
  project               Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([clientId])
  @@index([projectId])
}

model RevenueForecast {
  id                    String                @id @default(cuid())
  amount                Float
  confidence            Float                 @default(50) // percentage 0-100
  currency              String                @default("USD")
  type                  RevenueType
  description           String?
  source                String?
  
  // Date tracking
  forecastDate          DateTime              @default(now())
  expectedDate          DateTime
  monthYear             String                // YYYY-MM format for grouping
  
  // Relations
  clientId              String?
  client                Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId             String?
  project               Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([expectedDate])
  @@index([monthYear])
  @@index([clientId])
  @@index([projectId])
}

enum RevenueType {
  CONSULTING
  RETAINER
  PROJECT
  SUBSCRIPTION
  COMMISSION
  BONUS
  OTHER
}

enum RevenueStatus {
  PENDING
  RECEIVED
  OVERDUE
  CANCELLED
}

enum RecurringPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}
